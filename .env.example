# Domain and SSL Configuration
# For Squarespace-managed domains, use self-signed certificates (default)
# or HTTP-01 challenge if you can expose port 80 temporarily
DOMAIN=ollama.localhost.com
EMAIL=ollama@localhost.com

# SSL Certificate Options:
# 1. Self-signed certificates (default - works immediately, browser warning)
# 2. Let's Encrypt HTTP-01 challenge (requires port 80 accessible from internet)
# 3. Manual certificate upload to Squarespace

# For HTTP-01 challenge with Squarespace domains:
# Set USE_HTTP_CHALLENGE=true and ensure port 80 is accessible
# USE_HTTP_CHALLENGE=false

# DNS Provider API Tokens (only needed for DNS-01 challenge)
# Not available for Squarespace-managed domains
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Ollama Configuration
OLLAMA_IMAGE=ollama/ollama
OLLAMA_LOW_VRAM=true

# Docker Platform
DOCKER_PLATFORM=linux/amd64

# Resource Limits (auto-detected by setup scripts, but can override)
# OLLAMA_MEMORY_LIMIT=8g
# OLLAMA_CPU_LIMIT=4.0
# WEBUI_MEMORY_LIMIT=2g
# WEBUI_CPU_LIMIT=2.0
# CADDY_MEMORY_LIMIT=512m
# CADDY_CPU_LIMIT=1.0