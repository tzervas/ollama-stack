# Development and Testing Container for Ollama + Open-WebUI
FROM python:3.12-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    docker.io \
    docker-compose \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install uv package manager
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

# Set working directory
WORKDIR /app

# Copy project files
COPY . .

# Install Python dependencies (if any)
RUN uv pip install --system -r requirements.txt || pip install -r requirements.txt

# Install test dependencies
RUN uv pip install --system -r requirements-test.txt || pip install -r requirements-test.txt

# Make setup script executable
RUN chmod +x setup.py

# Default command
CMD ["python", "setup.py", "--help"]